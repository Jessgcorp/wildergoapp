{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}