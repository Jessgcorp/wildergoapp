{
  "expo": {
    "name": "WilderGo",
    "slug": "wildergo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wildergo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wildergo.app",
      "buildNumber": "34",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wildergo.app",
      "adaptiveIcon": {
        "backgroundColor": "#F5EFE6",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5EFE6",
          "dark": {
            "backgroundColor": "#1E1814"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-router",
        {
          "origin": false,
          "root": "app"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false,
        "root": "app"
      },
      "eas": {
        "projectId": "2817ea3f-7edb-47e1-a939-326cd3881b44"
      },
      "apiBaseUrl": "https://aa60d38e-336a-4c6c-8c7a-2e8f4ae13a3f-00-37dgmtff0mvif.picard.replit.dev"
    }
  }
}
