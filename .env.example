# Copy to ".env" in the project root and fill in real values.
# The server loads this via dotenv (see server/index.ts).

# --- Firebase Admin (required for sign up / sign in on the API) ---
# Recommended: download the service account JSON from Firebase Console:
#   Project settings → Service accounts → Generate new private key
# Save the file in this folder (gitignored) and point to it:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Alternative: paste the entire JSON as a single line (minified), escaped for .env:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}

# Optional: same as FIREBASE_SERVICE_ACCOUNT_PATH (Google standard name)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Web API key (Firebase Console → Project settings → Your apps → Web API key).
# Used by some flows; safe to add for parity with client config.
FIREBASE_WEB_API_KEY=

# --- Database (required if you use PostgreSQL-backed auth / badges) ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE
